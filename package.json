{
  "name": "outpost-host-bridge",
  "version": "0.10.3",
  "private": true,
  "type": "module",
  "scripts": {
    "preinstall": "node scripts/check-platform-deps.mjs",
    "check:deps:platform": "node scripts/check-platform-deps.mjs",
    "start": "node server.js",
    "dev": "vite",
    "build": "npx vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:ui": "vitest run src/tests/interactions.test.ts",
    "test:e2e": "playwright test --list",
    "lint": "eslint src --max-warnings=0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "bridge:orch:enqueue": "node bridge/orchestrator-enqueue.mjs",
    "bridge:orch:loop": "node bridge/orchestrator-loop.mjs"
  },
  "dependencies": {
    "express": "^4.19.2",
    "playwright": "^1.52.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "ws": "^8.18.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "rollup": "^4.58.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.3.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
